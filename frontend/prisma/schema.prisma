generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  role          String    @default("ADMIN") // ADMIN, EDITOR, VIEWER
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  activityLogs  ActivityLog[]
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  images      String[]
  category    String?
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  icon        String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Hero {
  id              String   @id @default(cuid())
  title           String
  subtitle        String
  backgroundImage String?
}

model Setting {
  id                String @id @default(cuid())
  phone             String
  email             String
  address           String
  commercialRegister String
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  timestamp DateTime @default(now())
}

model TeamMember {
  id          String   @id @default(cuid())
  name        String
  role        String
  bio         String?
  image       String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ServiceDetail {
  id          String   @id @default(cuid())
  title       String   // عنوان التفصيلة (مثل "التوريد")
  description String   // وصف طويل
  image       String?  // صورة توضيحية
  order       Int      @default(0)
  serviceId   String   // ربط بالخدمة الرئيسية
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CompanyImage {
  id          String   @id @default(cuid())
  title       String?  // عنوان الصورة (اختياري)
  image       String   // رابط الصورة
  category    String?  // تصنيف (مثلاً "team", "office", "projects")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
